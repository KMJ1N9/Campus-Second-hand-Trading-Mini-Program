<view class="page-container">
  <scroll-view class="form-scroll" scroll-y>
    <!-- 图片上传 -->
    <view class="form-section">
      <view class="form-label">商品图片 <text class="required">*</text></view>
      <image-upload
        images="{{form.images}}"
        bindchange="onImagesChange"
        error="{{errors.images}}"
      />
    </view>

    <!-- 商品标题 -->
    <view class="form-section">
      <view class="form-label">商品标题 <text class="required">*</text></view>
      <input
        class="form-input"
        placeholder="请输入商品标题（30字以内）"
        value="{{form.title}}"
        maxlength="30"
        bindinput="onFieldChange"
        data-field="title"
      />
      <view class="form-count">{{form.title.length || 0}}/30</view>
      <view class="form-error" wx:if="{{errors.title}}">{{errors.title}}</view>
    </view>

    <!-- 价格 -->
    <view class="form-section">
      <view class="form-label">价格 <text class="required">*</text></view>
      <view class="form-row">
        <view class="form-price-wrap">
          <text class="price-symbol">¥</text>
          <input
            class="form-input form-input-price"
            type="digit"
            placeholder="售价"
            value="{{form.price}}"
            bindinput="onFieldChange"
            data-field="price"
          />
        </view>
        <view class="form-price-wrap">
          <text class="price-symbol">¥</text>
          <input
            class="form-input form-input-price"
            type="digit"
            placeholder="原价（选填）"
            value="{{form.originalPrice}}"
            bindinput="onFieldChange"
            data-field="originalPrice"
          />
        </view>
      </view>
      <view class="form-error" wx:if="{{errors.price}}">{{errors.price}}</view>
    </view>

    <!-- 分类 -->
    <view class="form-section">
      <view class="form-label">分类 <text class="required">*</text></view>
      <view class="form-chips">
        <view
          class="form-chip {{form.category === item.id ? 'chip-active' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          wx:if="{{item.id !== 'all'}}"
          data-id="{{item.id}}"
          bindtap="onCategorySelect"
        >{{item.name}}</view>
      </view>
      <view class="form-error" wx:if="{{errors.category}}">{{errors.category}}</view>
    </view>

    <!-- 成色 -->
    <view class="form-section">
      <view class="form-label">成色 <text class="required">*</text></view>
      <view class="form-chips">
        <view
          class="form-chip {{form.condition === item.id ? 'chip-active' : ''}}"
          wx:for="{{conditions}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="onConditionSelect"
        >{{item.name}}</view>
      </view>
      <view class="form-error" wx:if="{{errors.condition}}">{{errors.condition}}</view>
    </view>

    <!-- 描述 -->
    <view class="form-section">
      <view class="form-label">详细描述 <text class="required">*</text></view>
      <textarea
        class="form-textarea"
        placeholder="描述商品状况、购买时间、使用时长等信息（500字以内）"
        value="{{form.description}}"
        maxlength="500"
        auto-height
        bindinput="onFieldChange"
        data-field="description"
      />
      <view class="form-count">{{form.description.length || 0}}/500</view>
      <view class="form-error" wx:if="{{errors.description}}">{{errors.description}}</view>
    </view>

    <!-- 交易地点 -->
    <view class="form-section">
      <view class="form-label">交易地点</view>
      <input
        class="form-input"
        placeholder="如：xx校区xx栋宿舍楼"
        value="{{form.location}}"
        bindinput="onFieldChange"
        data-field="location"
      />
    </view>

    <!-- 标签 -->
    <view class="form-section">
      <view class="form-label">标签</view>
      <input
        class="form-input"
        placeholder="用逗号分隔，如：考研,四六级 (最多5个)"
        value="{{tagInput}}"
        bindinput="onTagInput"
      />
    </view>

    <!-- 提交区域留白 -->
    <view style="height: 160rpx;"></view>
  </scroll-view>

  <!-- 底部提交按钮 -->
  <view class="publish-footer safe-area-bottom">
    <button
      class="btn btn-primary btn-block {{submitting ? 'btn-disabled' : ''}}"
      bindtap="onSubmit"
      disabled="{{submitting}}"
      loading="{{submitting}}"
    >{{submitting ? (isEditing ? '保存中...' : '发布中...') : (isEditing ? '保存修改' : '发布商品')}}</button>
  </view>
</view>
