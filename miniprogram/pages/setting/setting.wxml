<view class="page-container">
  <!-- 菜单列表 -->
  <view class="setting-section">
    <view class="setting-item" bindtap="onClearCache">
      <text class="setting-label">清除缓存</text>
      <view class="setting-right">
        <text class="setting-value">{{cacheSize}}</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="setting-section">
    <view class="setting-item" bindtap="onAbout">
      <text class="setting-label">关于我们</text>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item" bindtap="onFeedback">
      <text class="setting-label">意见反馈</text>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <!-- 关于弹窗 -->
  <view class="about-modal {{showAbout ? 'about-modal-show' : ''}}" catchtap="onCloseAbout">
    <view class="about-content" catchtap="stopPropagation">
      <view class="about-icon">🛒</view>
      <view class="about-title">校园二手交易</view>
      <view class="about-version">版本 1.0.0</view>
      <view class="about-desc">一个专注于校园内部的二手物品交易平台，让闲置物品找到新主人，共建绿色校园。</view>
      <button class="btn btn-primary btn-block" bindtap="onCloseAbout">知道了</button>
    </view>
  </view>
</view>
