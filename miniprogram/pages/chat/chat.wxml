<view class="chat-page">
  <scroll-view
    class="msg-scroll"
    scroll-y
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation
    enable-back-to-top
    bindscrolltoupper="loadMoreMessages"
    upper-threshold="50"
  >
    <view class="load-more-tip" wx:if="{{loadingMore}}">
      <text class="text-muted text-sm">加载中...</text>
    </view>
    <view class="load-more-tip" wx:elif="{{!hasMore && messages.length > 0}}">
      <text class="text-muted text-sm">没有更多消息了</text>
    </view>

    <view class="msg-list" wx:if="{{messages.length > 0}}">
      <block wx:for="{{messages}}" wx:key="_id">
        <view class="msg-row msg-left" wx:if="{{item.from_id !== myId}}">
          <image class="msg-avatar" src="{{targetUser.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="msg-bubble msg-bubble-left">{{item.content}}</view>
        </view>
        <view class="msg-row msg-right" wx:else>
          <view class="msg-bubble msg-bubble-right">{{item.content}}</view>
          <image class="msg-avatar" src="{{myAvatar}}" mode="aspectFill" />
        </view>
      </block>
    </view>

    <view class="chat-empty" wx:if="{{!loading && messages.length === 0}}">
      <text class="text-muted">开始聊天吧~</text>
    </view>

    <view id="msg-bottom"></view>
  </scroll-view>

  <view class="chat-input-bar safe-area-bottom">
    <input
      class="chat-input"
      value="{{inputValue}}"
      placeholder="输入消息..."
      placeholder-class="input-placeholder"
      bindinput="onInput"
      bindconfirm="onSend"
      confirm-type="send"
      adjust-position="{{true}}"
    />
    <button class="btn btn-primary btn-sm send-btn {{inputValue ? '' : 'btn-disabled'}}" bindtap="onSend">
      发送
    </button>
  </view>
</view>
