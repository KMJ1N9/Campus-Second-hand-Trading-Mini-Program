.detail-swiper {
  width: 100%;
  height: 500rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 价格区 */
.detail-price-section {
  padding: var(--space-4);
  background-color: var(--color-surface);
}

.detail-price {
  display: flex;
  align-items: baseline;
  gap: var(--space-2);
}

.original-price {
  text-decoration: line-through;
}

.detail-title {
  margin-top: var(--space-2);
  font-size: var(--text-lg);
  font-weight: 600;
  line-height: 1.5;
  word-break: break-word;
}

/* 信息卡片 */
.detail-card {
  background-color: var(--color-surface);
  margin-top: var(--space-2);
  padding: var(--space-4);
}

.detail-section-title {
  font-size: var(--text-base);
  font-weight: 700;
  margin-bottom: var(--space-3);
  padding-bottom: var(--space-2);
  border-bottom: 1rpx solid var(--color-border-light);
}

.detail-info-row {
  display: flex;
  align-items: center;
  padding: var(--space-2) 0;
  font-size: var(--text-sm);
}

.detail-info-label {
  width: 140rpx;
  color: var(--color-muted-foreground);
}

.detail-info-value {
  color: var(--color-foreground);
}

/* 描述 */
.detail-desc {
  font-size: var(--text-base);
  line-height: 1.8;
  color: var(--color-foreground);
  white-space: pre-wrap;
  word-break: break-word;
  overflow-wrap: break-word;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-3);
}

/* 卖家信息 */
.seller-info {
  display: flex;
  align-items: center;
}

.seller-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-full);
  margin-right: var(--space-3);
}

.seller-name {
  font-size: var(--text-base);
  font-weight: 600;
}

.seller-auth {
  font-size: var(--text-xs);
  color: var(--color-accent);
  margin-left: var(--space-1);
}

.seller-school {
  font-size: var(--text-sm);
  color: var(--color-muted-foreground);
  margin-top: 4rpx;
}

/* 底部操作栏 */
.detail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  background-color: var(--color-surface);
  border-top: 1rpx solid var(--color-border-light);
}

.footer-left {
  display: flex;
  gap: var(--space-2);
  flex-shrink: 0;
}

.footer-icon-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-1);
  min-width: 80rpx;
}

.footer-icon {
  font-size: var(--text-xl);
}

.footer-icon-text {
  font-size: var(--text-xs);
  color: var(--color-muted-foreground);
  margin-top: 2rpx;
}
