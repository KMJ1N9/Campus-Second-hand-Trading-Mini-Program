.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.upload-item {
  width: calc((100% - 32rpx) / 3);
  aspect-ratio: 1 / 1;
  border-radius: var(--radius-md);
  overflow: hidden;
  position: relative;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.upload-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.55);
  color: #FFFFFF;
  font-size: 24rpx;
  border-bottom-left-radius: var(--radius-md);
}

.upload-cover {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(0, 0, 0, 0.55);
  color: #FFFFFF;
  font-size: var(--text-xs);
}

.upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--color-muted);
  border: 2rpx dashed var(--color-border);
  box-sizing: border-box;
}

.upload-add-icon {
  font-size: 60rpx;
  color: var(--color-muted-foreground);
  line-height: 1;
  margin-bottom: 4rpx;
}

.upload-add-text {
  font-size: var(--text-xs);
  color: var(--color-muted-foreground);
}

.upload-tip {
  font-size: var(--text-xs);
  color: var(--color-muted-foreground);
  margin-top: var(--space-2);
}
