<view class="page-container">
  <!-- 头像区 -->
  <view class="profile-avatar-section">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="profile-avatar" src="{{form.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="avatar-tip">点击更换微信头像</view>
    </button>
  </view>

  <!-- 信息表单 -->
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">昵称</text>
      <input
        class="form-input"
        type="nickname"
        value="{{form.nickname}}"
        bindchange="onNicknameChange"
        maxlength="20"
      />
    </view>
    <view class="form-error" wx:if="{{errors.nickname}}">{{errors.nickname}}</view>

    <view class="form-item">
      <text class="form-label">手机号</text>
      <input
        class="form-input"
        value="{{form.phone}}"
        placeholder="请输入手机号"
        placeholder-class="input-placeholder"
        bindinput="onInputChange"
        data-field="phone"
        type="number"
        maxlength="11"
      />
    </view>
    <view class="form-error" wx:if="{{errors.phone}}">{{errors.phone}}</view>

    <view class="form-item">
      <text class="form-label">微信号</text>
      <input
        class="form-input"
        value="{{form.wechat_id}}"
        placeholder="请输入微信号"
        placeholder-class="input-placeholder"
        bindinput="onInputChange"
        data-field="wechat_id"
        maxlength="30"
      />
    </view>

    <view class="form-item">
      <text class="form-label">学校</text>
      <input
        class="form-input"
        value="{{form.school}}"
        placeholder="请输入学校名称"
        placeholder-class="input-placeholder"
        bindinput="onInputChange"
        data-field="school"
        maxlength="30"
      />
    </view>

    <view class="form-item">
      <text class="form-label">学号</text>
      <input
        class="form-input"
        value="{{form.student_id}}"
        placeholder="请输入学号"
        placeholder-class="input-placeholder"
        bindinput="onInputChange"
        data-field="student_id"
        maxlength="20"
      />
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-wrap">
    <button class="btn btn-primary btn-block {{saving ? 'btn-disabled' : ''}}" bindtap="onSave" disabled="{{saving}}">
      {{saving ? '保存中...' : '保存'}}
    </button>
  </view>
</view>
