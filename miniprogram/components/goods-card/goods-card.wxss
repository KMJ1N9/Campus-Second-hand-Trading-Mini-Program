.goods-card {
  background-color: var(--color-surface);
  overflow: hidden;
  box-sizing: border-box;
}
.goods-card:active {
  opacity: 0.85;
}

/* 网格布局 */
.card-grid {
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}
.card-grid .card-image-wrap {
  width: 100%;
  aspect-ratio: 1 / 1;
  position: relative;
  overflow: hidden;
}
.card-grid .card-image {
  width: 100%;
  height: 100%;
}
.card-grid .card-body {
  padding: var(--space-2);
}
.card-grid .card-title {
  font-size: var(--text-sm);
  line-height: 1.4;
  height: 70rpx;
}

/* 列表布局 */
.card-list {
  display: flex;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--space-2);
}
.card-list .card-image-wrap {
  width: 240rpx;
  min-width: 240rpx;
  height: 240rpx;
  position: relative;
  overflow: hidden;
}
.card-list .card-image {
  width: 100%;
  height: 100%;
}
.card-list .card-body {
  flex: 1;
  padding: var(--space-3);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.card-list .card-title {
  font-size: var(--text-base);
  font-weight: 500;
  line-height: 1.5;
}

/* 状态标签 */
.card-status-tag {
  position: absolute;
  top: 0;
  right: 0;
  border-top-right-radius: var(--radius-lg);
  border-bottom-left-radius: var(--radius-lg);
  padding: 6rpx 16rpx;
  font-size: var(--text-xs);
  font-weight: 600;
}

/* 价格区 */
.card-price-row {
  display: flex;
  align-items: baseline;
  gap: var(--space-2);
  margin-top: var(--space-1);
}
.card-price-value {
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-foreground);
}
.card-price-original {
  font-size: var(--text-xs);
  color: var(--color-muted-foreground);
  text-decoration: line-through;
}

/* 元信息行 */
.card-meta-row {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-top: var(--space-1);
}
.card-meta-text {
  font-size: var(--text-xs);
  color: var(--color-muted-foreground);
}

/* 标签行 */
.card-tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
  margin-top: var(--space-1);
}
