<view class="page-container">
  <!-- 用户信息区 -->
  <view class="user-header">
    <block wx:if="{{isLoggedIn}}">
      <!-- 已登录：原生组件读取微信头像 -->
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="user-avatar" src="{{userInfo.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
      </button>
      <view class="user-info">
        <input
          class="user-name-input"
          type="nickname"
          value="{{userInfo.nickname}}"
          bindchange="onNicknameChange"
        />
      </view>
      <view class="user-arrow" bindtap="onGoProfile">›</view>
    </block>
    <block wx:else>
      <!-- 未登录：直接使用原生组件弹出选择 -->
      <button class="avatar-btn login-btn" open-type="chooseAvatar" bindchooseavatar="onLoginChooseAvatar">
        <image class="user-avatar" src="/assets/images/default-avatar.png" mode="aspectFill" />
      </button>
      <view class="user-info">
        <input
          class="user-name-input login-name-input"
          type="nickname"
          placeholder="点击获取微信昵称"
          bindchange="onLoginNicknameChange"
        />
      </view>
      <view class="user-arrow">›</view>
    </block>
  </view>

  <!-- 数据统计 -->
  <view class="stats-bar">
    <view class="stat-item" bindtap="onGoMyPublish">
      <text class="stat-num">{{stats.publishCount}}</text>
      <text class="stat-label">发布</text>
    </view>
    <view class="stat-item" bindtap="onGoCollection">
      <text class="stat-num">{{stats.collectCount}}</text>
      <text class="stat-label">收藏</text>
    </view>
    <view class="stat-item" bindtap="onGoHistory">
      <text class="stat-num">{{stats.historyCount}}</text>
      <text class="stat-label">浏览</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onGoMyPublish">
      <text>我的发布</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onGoCollection">
      <text>我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onGoHistory">
      <text>浏览历史</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="onGoMessage">
      <text>消息通知</text>
      <view class="menu-right">
        <view class="menu-badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
    <view class="menu-item" bindtap="onGoSetting">
      <text>设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
