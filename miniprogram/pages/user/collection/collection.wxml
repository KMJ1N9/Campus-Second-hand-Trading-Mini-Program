<view class="page-container">
  <!-- 加载态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="text-muted">加载中...</text>
  </view>

  <!-- 收藏列表 -->
  <view class="collect-list" wx:if="{{!loading && list.length > 0}}">
    <block wx:for="{{list}}" wx:key="_id">
      <goods-card goods="{{item}}" layout="list" bindtap="onGoodsTap" />
    </block>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:if="{{!loading && list.length === 0}}"
    title="还没有收藏"
    description="去首页看看有没有心仪的商品吧"
  />

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{list.length > 0}}">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:elif="{{!hasMore}}">— 没有更多了 —</text>
  </view>
</view>
