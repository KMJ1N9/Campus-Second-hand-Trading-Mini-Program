<view class="page-container">
  <!-- 加载态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="text-muted">加载中...</text>
  </view>

  <!-- 消息列表 -->
  <view class="msg-page-list" wx:if="{{!loading && list.length > 0}}">
    <block wx:for="{{list}}" wx:key="userId">
      <view class="msg-item" bindtap="onOpenChat" data-user-id="{{item.userId}}" data-goods-id="{{item.goodsId}}">
        <view class="msg-item-left">
          <image class="msg-item-avatar" src="{{item.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
        </view>
        <view class="msg-item-body">
          <view class="flex-between">
            <text class="msg-item-name">{{item.nickname || '匿名用户'}}</text>
            <text class="msg-item-time">{{item.timeText}}</text>
          </view>
          <view class="flex-between mt-1">
            <text class="msg-item-preview text-ellipsis">{{item.lastMessage}}</text>
            <view class="msg-item-badge" wx:if="{{item.unread > 0}}">{{item.unread > 99 ? '99+' : item.unread}}</view>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:if="{{!loading && list.length === 0}}"
    title="暂无消息"
    description="去看看商品详情，联系卖家吧"
  />
</view>
